        \<Iota\>\<omega\>\<sigma\>\<iota\>\<alpha\>\<varsigma\>:20
        \<Iota\>\<varepsilon\>\<chi\>\<omicron\>\<nu\>\<iota\>\<alpha\>\<varsigma\>:7
        \<Sigma\>\<alpha\>\<lambda\>\<alpha\>\<theta\>\<iota\>\<eta\>\<lambda\>:16
        \<Zeta\>\<omicron\>\<rho\>\<omicron\>\<beta\>\<alpha\>\<beta\>\<varepsilon\>\<lambda\>:34
        \<Alpha\>\<beta\>\<iota\>\<omicron\>\<upsilon\>\<delta\>:13
        \<Epsilon\>\<lambda\>\<iota\>\<alpha\>\<kappa\>\<varepsilon\>\<iota\>\<mu\>:0
        \<Alpha\>\<zeta\>\<omega\>\<rho\>:2
        \<Sigma\>\<alpha\>\<delta\>\<omega\>\<kappa\>:43
        \<Alpha\>\<chi\>\<varepsilon\>\<iota\>\<mu\>:9
        \<Epsilon\>\<lambda\>\<iota\>\<omicron\>\<upsilon\>\<delta\>:0
        \<Epsilon\>\<lambda\>\<varepsilon\>\<alpha\>\<zeta\>\<alpha\>\<rho\>:103
        \<Mu\>\<alpha\>\<tau\>\<theta\>\<alpha\>\<nu\>:2
        \<Iota\>\<alpha\>\<kappa\>\<omega\>\<beta\>:404
        \<Iota\>\<omega\>\<sigma\>\<eta\>\<varphi\>:227
